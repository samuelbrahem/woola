# Google Maps JS API key (Maps JavaScript API enabled, HTTP-referrer restricted to woola.ca)
# Without it, the site falls back to the Leaflet/OpenStreetMap coverage map.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Resend API key for the Second Opinion upload form (resend.com)
# Without it, /api/second-opinion returns a friendly "call us" message.
RESEND_API_KEY=

# Where Second Opinion submissions are delivered
ESTIMATING_EMAIL=services@woola.ca
